# Copy to .env.local and fill in.
# Anything prefixed NEXT_PUBLIC_ is embedded in the client bundle — never
# put the service-role key here. That lives only in Cloud Run secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API (Cloud Run URL in prod; localhost:8000 in dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Sentry (optional in dev; set in Vercel prod env)
NEXT_PUBLIC_SENTRY_DSN=
