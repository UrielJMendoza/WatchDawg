# Copy to .env and fill in. Never commit the filled-in file.
# In production these are injected by Cloud Run --set-secrets pulling
# from Google Secret Manager. See infra/gcp/WIF_SETUP.md.

# ── Runtime ────────────────────────────────────────────────────────────
ENV=dev

# ── Supabase ───────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated origins. Leave empty in dev to allow only localhost:3000
# (which you must still add explicitly). Vercel preview URLs match by regex.
ALLOWED_ORIGINS=http://localhost:3000

# ── Cron ───────────────────────────────────────────────────────────────
# Random 32+ char string. Any value with <16 chars fails validation.
# Generate: `openssl rand -hex 24`
CRON_SECRET=

# ── Sentry (optional) ──────────────────────────────────────────────────
SENTRY_DSN=

# ── Phase 2+ integrations (optional; add as ingestors land) ────────────
ANTHROPIC_API_KEY=
AISSTREAM_API_KEY=
NEWSDATA_API_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
REDDIT_USERNAME=
